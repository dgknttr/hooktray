{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Webhook": {
    "MaxBodyBytes": 1048576,
    "BodyPreviewLength": 200
  },
  "Session": {
    "Ttl": "00:30:00",
    "CleanupInterval": "00:05:00"
  },
  "RateLimit": {
    "MaxWebhooksPerMinute": 60,
    "MaxTokenCreationsPerMinutePerIp": 10
  },
  "Cors": {
    "AllowedOrigins": [ "http://localhost:3000" ]
  }
}
